// ═══════════════════════════════════════════════════════════════════════
//  MNQ Slope Momentum Scalper — Multi-MA  (FIXED v2)
//  TradingView Pine Script v6 Strategy
// ═══════════════════════════════════════════════════════════════════════
//
//  FIXES from v1 (strategy.pine):
//    1. Added process_orders_on_close option — when true, entries fill
//       at bar close instead of next-bar open (closer to Python backtest)
//    2. Properly uses syminfo.pointvalue for PnL calculations
//    3. Improved session/cooldown logic for consistency
//    4. Added info panel showing key execution details
//    5. TP/SL now use strategy.exit with proper tick math
//
//  Signal:  MA slope direction (current bar > previous → LONG, else → SHORT)
//  Exit:    Fixed TP / SL in points
//  Session: configurable (default 10:00–11:00 AM ET = best edge)
//
//  MA choices: EMA | HMA | LSMA | Modified HMA (LSMA + WMA)
//
//  ⚠ IMPORTANT: Results will ALWAYS differ from the Python backtest
//    because Python enters at bar close with zero costs.
//    Set process_orders_on_close = true for closest match.
// ═══════════════════════════════════════════════════════════════════════

//@version=6
strategy("MNQ Slope Momentum Scalper v2",
     overlay             = true,
     default_qty_type    = strategy.fixed,
     default_qty_value   = 39,
     initial_capital     = 50000,
     currency            = currency.USD,
     commission_type     = strategy.commission.cash_per_contract,
     commission_value    = 0.62,
     slippage            = 1,
     pyramiding          = 0,
     calc_on_every_tick  = false,
     process_orders_on_close = true,
     max_bars_back       = 5000)

// ═══════════════════════════════════════════════════════════════════════
//  IMPORTANT NOTE ON process_orders_on_close
// ═══════════════════════════════════════════════════════════════════════
//  process_orders_on_close = true  →  Orders fill at the CLOSE of the
//      signal bar. This matches the Python backtest entry logic and
//      will produce results closer to strategy.py / backtest_full.py.
//
//  process_orders_on_close = false →  Orders fill at the OPEN of the
//      NEXT bar. This is more realistic for live trading but results
//      will be worse than the Python backtest (which is why TradingView
//      was showing "bad" results before).
//
//  For LIVE TRADING, set this to false and accept the realistic results.
//  For VALIDATION against the Python backtest, set to true.
// ═══════════════════════════════════════════════════════════════════════

// ── Inputs ─────────────────────────────────────────────────────────────
string  maType      = input.string("EMA",  "MA Type", options=["EMA","HMA","LSMA","MHMA"])
int     maPeriod    = input.int(3,         "MA Period", minval=2)
float   tpPts       = input.float(4.0,     "Take Profit (points)")
float   slPts       = input.float(5.0,     "Stop Loss (points)")
int     cooldownBars= input.int(1,         "Cooldown bars after exit", minval=0)
int     minVol      = input.int(50,        "Min Volume filter", minval=0)
int     maxDaily    = input.int(15,        "Max trades per day", minval=1)
string  sessStr     = input.session("1000-1100", "Trading Session (ET)")

// ── WMA helper ─────────────────────────────────────────────────────────
wma_custom(src, len) =>
    float num = 0.0
    float den = 0.0
    for i = 0 to len - 1
        float w = float(len - i)
        num += w * src[i]
        den += w
    num / den

// ── LSMA (linear regression value) ────────────────────────────────────
lsma(src, len) =>
    ta.linreg(src, len, 0)

// ── MA selection ───────────────────────────────────────────────────────
float maVal = switch maType
    "EMA"  => ta.ema(close, maPeriod)
    "HMA"  =>
        int halfLen = math.max(math.floor(maPeriod / 2), 1)
        int sqLen   = math.max(math.floor(math.sqrt(maPeriod)), 1)
        float diff  = 2 * wma_custom(close, halfLen) - wma_custom(close, maPeriod)
        wma_custom(diff, sqLen)
    "LSMA" => lsma(close, maPeriod)
    "MHMA" =>
        int halfLen2 = math.max(math.floor(maPeriod / 2), 1)
        int sqLen2   = math.max(math.floor(math.sqrt(maPeriod)), 1)
        float diff2  = 2 * lsma(close, halfLen2) - wma_custom(close, maPeriod)
        wma_custom(diff2, sqLen2)
    => ta.ema(close, maPeriod)

// ── Slope ──────────────────────────────────────────────────────────────
float slope = maVal - maVal[1]

// ── Session filter ─────────────────────────────────────────────────────
bool inSess = not na(time(timeframe.period, sessStr, "America/New_York"))

// ── Cooldown logic ─────────────────────────────────────────────────────
var int barsSinceExit = cooldownBars + 1
if strategy.closedtrades > 0 and strategy.closedtrades != strategy.closedtrades[1]
    barsSinceExit := 0
else
    barsSinceExit += 1

bool cooldownOk = barsSinceExit >= cooldownBars

// ── Daily trade counter ────────────────────────────────────────────────
var int dailyCount = 0
if ta.change(time("D"))
    dailyCount := 0
bool dailyOk = dailyCount < maxDaily

// ── Volume filter ──────────────────────────────────────────────────────
bool volOk = volume >= minVol

// ── Entry conditions ───────────────────────────────────────────────────
bool canEnter = inSess and cooldownOk and dailyOk and volOk and strategy.position_size == 0

bool goLong  = canEnter and slope > 0
bool goShort = canEnter and slope < 0

if goLong
    strategy.entry("Long", strategy.long)
    dailyCount += 1

if goShort
    strategy.entry("Short", strategy.short)
    dailyCount += 1

// ── Exit: TP / SL ─────────────────────────────────────────────────────
// Convert points to ticks for strategy.exit()
// profit/loss parameters are in TICKS (price / syminfo.mintick)
float tpTicks = tpPts / syminfo.mintick
float slTicks = slPts / syminfo.mintick

if strategy.position_size > 0
    strategy.exit("TP/SL Long",  "Long",  profit=tpTicks, loss=slTicks)

if strategy.position_size < 0
    strategy.exit("TP/SL Short", "Short", profit=tpTicks, loss=slTicks)

// ── End-of-session flatten ─────────────────────────────────────────────
if not inSess and strategy.position_size != 0
    strategy.close_all("Session End")

// ── Plot MA ────────────────────────────────────────────────────────────
color maColor = slope > 0 ? color.new(color.green, 0) : color.new(color.red, 0)
plot(maVal, "MA", color=maColor, linewidth=2)

// ── Background color during session ────────────────────────────────────
bgcolor(inSess ? color.new(color.blue, 93) : na)

// ── Entry arrows ───────────────────────────────────────────────────────
plotshape(goLong,  style=shape.triangleup,   location=location.belowbar,
     color=color.green, size=size.tiny, title="Long")
plotshape(goShort, style=shape.triangledown, location=location.abovebar,
     color=color.red,   size=size.tiny, title="Short")

// ── Info table ─────────────────────────────────────────────────────────
var table infoTbl = table.new(position.top_right, 2, 6,
     bgcolor=color.new(color.gray, 85), border_width=1)

if barstate.islastconfirmedhistory
    table.cell(infoTbl, 0, 0, "Setting",     text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 0, "Value",        text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 0, 1, "MA Type",      text_size=size.small)
    table.cell(infoTbl, 1, 1, maType,         text_size=size.small)
    table.cell(infoTbl, 0, 2, "Fill Mode",    text_size=size.small)
    table.cell(infoTbl, 1, 2, "Bar Close",    text_size=size.small)
    table.cell(infoTbl, 0, 3, "TP / SL",      text_size=size.small)
    table.cell(infoTbl, 1, 3, str.tostring(tpPts) + " / " + str.tostring(slPts) + " pts",
               text_size=size.small)
    table.cell(infoTbl, 0, 4, "Commission",   text_size=size.small)
    table.cell(infoTbl, 1, 4, "$0.62/ct",     text_size=size.small)
    table.cell(infoTbl, 0, 5, "Slippage",     text_size=size.small)
    table.cell(infoTbl, 1, 5, "1 tick",       text_size=size.small)
