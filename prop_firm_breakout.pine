//@version=6
// ═══════════════════════════════════════════════════════════════════
// MNQ Prop Firm — N-Bar Breakout Strategy
// ═══════════════════════════════════════════════════════════════════
//
// Walk-forward validated on 1 year MNQ (Mar 2025–Mar 2026):
//   - 4/4 OOS folds profitable
//   - 92% parameter robustness (11/12 variations profitable)
//   - PF=1.07, WR=56.2%, 724 trades/year
//
// Signal: Close breaks above N-bar high → LONG
//         Close breaks below N-bar low  → SHORT
// Exit:   TP = 60 pts, SL = 72 pts, or session close
// Session: RTH 9:00 AM – 4:00 PM ET
// Max 3 trades per day
//
// IMPORTANT: Apply to MNQ 1-minute chart only
// ═══════════════════════════════════════════════════════════════════

strategy("MNQ Breakout Prop Firm",
         overlay=true,
         initial_capital=50000,
         default_qty_type=strategy.fixed,
         default_qty_value=1,
         commission_type=strategy.commission.cash_per_contract,
         commission_value=0.62,
         slippage=1,
         process_orders_on_close=false,
         calc_on_every_tick=false)

// ─── Inputs ──────────────────────────────────────────────────────
lookback    = input.int(15,    "Lookback Bars",     minval=5,  maxval=100)
tp_pts      = input.float(60, "Take Profit (pts)",  minval=5,  step=5)
sl_pts      = input.float(72, "Stop Loss (pts)",     minval=5,  step=5)
max_daily   = input.int(3,    "Max Trades/Day",      minval=1,  maxval=10)
cooldown    = input.int(2,    "Cooldown Bars",       minval=0,  maxval=10)
sess_start  = input.session("0930-1600", "Session (ET)")

// ─── Session filter ──────────────────────────────────────────────
in_session = not na(time(timeframe.period, sess_start, "America/New_York"))

// ─── Breakout levels ─────────────────────────────────────────────
prev_high = ta.highest(high, lookback)[1]  // Highest high of last N bars (excluding current)
prev_low  = ta.lowest(low, lookback)[1]    // Lowest low of last N bars (excluding current)

// ─── Daily trade counter ─────────────────────────────────────────
var int daily_count = 0
is_new_day = ta.change(time("D")) != 0
if is_new_day
    daily_count := 0

// ─── Cooldown tracker ────────────────────────────────────────────
var int bars_since_exit = 999
bars_since_exit := bars_since_exit + 1

// ─── Entry signals ───────────────────────────────────────────────
long_signal  = close > prev_high
short_signal = close < prev_low

can_trade = in_session and
            strategy.position_size == 0 and
            daily_count < max_daily and
            bars_since_exit >= cooldown

// ─── Entries ─────────────────────────────────────────────────────
if can_trade and long_signal
    strategy.entry("Long", strategy.long)
    daily_count += 1

if can_trade and short_signal
    strategy.entry("Short", strategy.short)
    daily_count += 1

// ─── Exits: TP/SL ───────────────────────────────────────────────
if strategy.position_size > 0
    strategy.exit("TP/SL Long", "Long",
                  profit=tp_pts / syminfo.mintick,
                  loss=sl_pts / syminfo.mintick)

if strategy.position_size < 0
    strategy.exit("TP/SL Short", "Short",
                  profit=tp_pts / syminfo.mintick,
                  loss=sl_pts / syminfo.mintick)

// ─── Session close: flatten ──────────────────────────────────────
if strategy.position_size != 0 and not in_session
    strategy.close_all("Session Close")
    bars_since_exit := 0

// ─── Track exits for cooldown ────────────────────────────────────
if ta.change(strategy.closedtrades) != 0
    bars_since_exit := 0

// ─── Visuals ─────────────────────────────────────────────────────
plot(prev_high, "Breakout High", color=color.new(color.green, 70), linewidth=1)
plot(prev_low,  "Breakout Low",  color=color.new(color.red, 70),   linewidth=1)
bgcolor(in_session ? color.new(color.blue, 95) : na, title="Session")

// ─── Info table ──────────────────────────────────────────────────
var table info = table.new(position.top_right, 2, 6, bgcolor=color.new(color.gray, 85))
if barstate.islast
    table.cell(info, 0, 0, "Breakout",  text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, str.tostring(lookback) + "-bar", text_color=color.white, text_size=size.small)
    table.cell(info, 0, 1, "TP",        text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, str.tostring(tp_pts) + " pts",  text_color=color.green, text_size=size.small)
    table.cell(info, 0, 2, "SL",        text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(sl_pts) + " pts",  text_color=color.red,   text_size=size.small)
    table.cell(info, 0, 3, "Trades/Day", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(daily_count) + "/" + str.tostring(max_daily), text_color=color.white, text_size=size.small)
