// ═══════════════════════════════════════════════════════════════════
//  MNQ Inside Bar Breakout Strategy — CORRECTED
//  
//  This is the best strategy found after testing 1,267 combinations
//  across 40 days of MNQZ5 data with realistic execution.
//  
//  Signal: Inside bar breakout
//  - An "inside bar" is a bar whose range is entirely within the 
//    previous bar's range (lower high, higher low)
//  - LONG: when the bar after an inside bar closes above the 
//    containing bar's high
//  - SHORT: when the bar after an inside bar closes below the
//    containing bar's low
//  
//  TP: 8 points | SL: 10 points
//  Session: RTH Morning 10:00-11:00 AM ET
//  
//  Backtest result (40 days, realistic execution):
//    73 trades, 64.4% WR, PF=1.19, $4,094 profit
//  
//  ⚠ This is a MARGINAL edge. Paper-trade first.
// ═══════════════════════════════════════════════════════════════════

//@version=6
strategy("MNQ Inside Bar Breakout",
     overlay          = true,
     initial_capital   = 25000,
     default_qty_type  = strategy.fixed,
     default_qty_value = 39,
     commission_type   = strategy.commission.cash_per_contract,
     commission_value  = 0.62,
     slippage          = 1,
     process_orders_on_close = false,
     calc_on_every_tick = false,
     margin_long       = 100,
     margin_short      = 100)

// ── INPUTS ────────────────────────────────────────────────────────
tp_pts    = input.float(8.0,  "Take Profit (points)", step=0.25)
sl_pts    = input.float(10.0, "Stop Loss (points)",   step=0.25)
sess_start = input.session("1000-1100", "Trading Session (ET)")
min_vol   = input.int(50,    "Minimum Volume Filter", minval=0)
max_daily = input.int(20,    "Max Trades Per Day",    minval=1)

// ── SESSION FILTER ────────────────────────────────────────────────
in_session = not na(time(timeframe.period, sess_start, "America/New_York"))

// ── INSIDE BAR DETECTION ──────────────────────────────────────────
// An inside bar has: high <= prev_high AND low >= prev_low
is_inside = high[1] <= high[2] and low[1] >= low[2]

// ── BREAKOUT SIGNALS ──────────────────────────────────────────────
// After an inside bar, look for breakout of the containing bar's range
container_high = high[2]
container_low  = low[2]

long_signal  = is_inside and close > container_high
short_signal = is_inside and close < container_low

// ── TRADE COUNTING ────────────────────────────────────────────────
var int daily_trades = 0
if dayofweek != dayofweek[1]
    daily_trades := 0

can_trade = in_session and daily_trades < max_daily
can_trade := can_trade and (min_vol == 0 or volume >= min_vol)

// ── ENTRY LOGIC ───────────────────────────────────────────────────
if can_trade and strategy.position_size == 0
    if long_signal
        strategy.entry("Long", strategy.long)
        daily_trades += 1
    else if short_signal
        strategy.entry("Short", strategy.short)
        daily_trades += 1

// ── EXIT LOGIC (Fixed TP/SL) ──────────────────────────────────────
if strategy.position_size > 0
    strategy.exit("Long TP/SL", "Long",
         profit = tp_pts / syminfo.mintick,
         loss   = sl_pts / syminfo.mintick)

if strategy.position_size < 0
    strategy.exit("Short TP/SL", "Short",
         profit = tp_pts / syminfo.mintick,
         loss   = sl_pts / syminfo.mintick)

// ── END-OF-SESSION FLATTEN ────────────────────────────────────────
if not in_session and strategy.position_size != 0
    strategy.close_all("Session End")

// ── VISUAL MARKERS ────────────────────────────────────────────────
// Mark inside bars
bgcolor(is_inside ? color.new(color.yellow, 90) : na)

// Mark breakout entries
plotshape(long_signal and can_trade and strategy.position_size == 0,
     title="Long Entry", location=location.belowbar,
     style=shape.triangleup, color=color.green, size=size.small)
plotshape(short_signal and can_trade and strategy.position_size == 0,
     title="Short Entry", location=location.abovebar,
     style=shape.triangledown, color=color.red, size=size.small)

// ── INFO PANEL ────────────────────────────────────────────────────
var table info = table.new(position.top_right, 2, 6)
if barstate.islast
    table.cell(info, 0, 0, "Strategy", text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 0, "Inside Bar Breakout", text_color=color.white, bgcolor=color.gray)
    table.cell(info, 0, 1, "TP/SL", text_color=color.white)
    table.cell(info, 1, 1, str.tostring(tp_pts) + " / " + str.tostring(sl_pts) + " pts", text_color=color.white)
    table.cell(info, 0, 2, "Session", text_color=color.white)
    table.cell(info, 1, 2, sess_start, text_color=color.white)
    table.cell(info, 0, 3, "Contracts", text_color=color.white)
    table.cell(info, 1, 3, str.tostring(strategy.initial_capital), text_color=color.white)
    table.cell(info, 0, 4, "Commission", text_color=color.white)
    table.cell(info, 1, 4, "$0.62/ct/side", text_color=color.white)
    table.cell(info, 0, 5, "⚠ Edge", text_color=color.yellow)
    table.cell(info, 1, 5, "Marginal (PF≈1.19)", text_color=color.yellow)
